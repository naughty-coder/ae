	public function preParseFile() {

		$list = $this->ozonRequest(
	        $this->base . 'v1/description-category/tree',
	        [
	            "language" => "RU"
	        ]
	    );

	    print_r($list);
	    die;
// https://api-seller.ozon.ru/v1/description-category/tree


		$this->products = [];

		$allProducts = [];
		$lastId = '';

		do {
		    $list = $this->ozonRequest(
		        $this->base . '/v3/product/list',
		        [
		            'filter' => ['visibility' => 'ALL'],
		            'last_id' => $lastId,
		            'limit' => 1000
		        ]
		    );

		    foreach ($list['result']['items'] ?? [] as $item) {
		        $allProducts[] = $item['product_id'];
		    }

		    $lastId = $list['result']['last_id'] ?? '';

		} while ($lastId);

		if (!$allProducts) die('Нет товаров');

		$chunks = array_chunk($allProducts, 100);

		foreach ($chunks as $chunk) {

		    $info =$this->ozonRequest(
		        $this->base . '/v3/product/info/list',
		        ['product_id' => $chunk]
		    );

		    foreach ($info['items'] ?? [] as $item) {
		    	$qty = 0;

		    	$sku = false;
		    	foreach ($item['stocks']['stocks'] as $stock) {
		    		$sku = $stock['sku'];
		    		$qty += $stock['present'];
		    	}

		        $id = $item['id'];

		        $this->products[$id] = [
		            'id'          => $id,
		            'sku'         => $sku,
		            'name'        => $item['name'],
		            'image'       => $item['primary_image'] ? reset($item['primary_image']) : false,
		            'images'      => $item['images'] ?? [],
		            'qty'         => $qty,
		            'href'        => 'https://www.ozon.ru/product/' . $sku,
		            'attributes'  => [],
		            'params'      => [],
		        ];
		    }
		}

		/**
		 * 3️⃣ ХАРАКТЕРИСТИКИ (ИСПРАВЛЕНО)
		 */
		$cursor = '';

		do {
		    $attrs =$this->ozonRequest(
		        $this->base . '/v4/product/info/attributes',
		        [
		            'filter' => [
		                'product_id' => $allProducts,
		                'visibility' => 'ALL'
		            ],
		            'limit' => 1000,
		            'cursor' => $cursor,
		            'sort_dir' => 'ASC'
		        ]
		    );

		    // print '<pre>';
		    // print_r($attrs);
		    // die;

		    foreach ($attrs['result'] ?? [] as $item) {
		        $id = $item['id'];
		        if (!isset($this->products[$id])) continue;

		        foreach ($item['attributes'] as $attr) {
		            $values = [];

		            foreach ($attr['values'] as $v) {
		                $values[] = $v['value'];
		            }

		            $this->products[$id]['attributes'][$attr['id']] = implode(', ', $values);
		        }

		        foreach (['barcode', 'height', 'depth', 'width', 'dimension_unit', 'weight', 'weight_unit', 'description_category_id'] as $key) { 
		        	if (isset($item[$key])) {
				        $this->products[$id]['params'][$key] = $item[$key];
				    }
			    }
		    }

		    $cursor = $attrs['result']['cursor'] ?? '';

		} while ($cursor);

	    print '<pre>';
	    print_r($this->products);
	    die;

		/**
		 * 4️⃣ ОПИСАНИЯ (иногда отдельный метод)
		 */
		foreach ($chunks as $chunk) {

		    $desc =$this->ozonRequest(
		        $this->base . '/v1/product/info/description',
		        ['product_id' => $chunk]
		    );

		    foreach ($desc['result'] ?? [] as $item) {
		        $id = $item['product_id'];
		        if (isset($products[$id])) {
		            $products[$id]['description'] = $item['description'] ?? '';
		        }
		    }
		}

		/**
		 * 5️⃣ ЦЕНЫ (cursor pagination)
		 */
		$cursor = '';

		do {
		    $prices =$this->ozonRequest(
		        $this->base . '/v5/product/info/prices',
		        [
		            'cursor' => $cursor,
